          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"image\": \"data:image/jpeg;base64,YOUR_BASE64_HERE\",\n  \"model\": \"k-nearest_neighbors_model\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5000/predict",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["predict"]
        }
      }
    },
    {
      "name": "9. Predict - Naive Bayes",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"image\": \"data:image/jpeg;base64,YOUR_BASE64_HERE\",\n  \"model\": \"naive_bayes_model\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5000/predict",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["predict"]
        }
      }
    },
    {
      "name": "10. Predict - CNN (Deep Learning)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"image\": \"data:image/jpeg;base64,YOUR_BASE64_HERE\",\n  \"model\": \"cnn_model\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5000/predict",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["predict"]
        },
        "description": "Prediction using Deep Learning CNN model"
      }
    },
    {
      "name": "11. Batch Prediction",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"images\": [\n    \"data:image/jpeg;base64,IMAGE1_BASE64\",\n    \"data:image/jpeg;base64,IMAGE2_BASE64\",\n    \"data:image/jpeg;base64,IMAGE3_BASE64\"\n  ],\n  \"model\": \"random_forest_model\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5000/predict/batch",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["predict", "batch"]
        },
        "description": "Predict multiple images at once"
      }
    }
  ]
}
